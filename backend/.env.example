PORT=4000

# Firebase Admin (autenticação)
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# PostgreSQL — formato: postgresql://USER:PASS@HOST:PORT/DB?schema=public
# Neon: cole a connection string com sslmode=require
# Local: postgresql://postgres:postgres@localhost:5432/futstore?schema=public
DATABASE_URL=

ALLOWED_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175
SHIPPING_FIXED=25

# === Envio de e-mail (Gmail SMTP) ===
# 1. Ativa 2FA em myaccount.google.com/security
# 2. Cria uma App Password em myaccount.google.com/apppasswords
# 3. Cola a senha de 16 chars (sem espaços) em MAIL_PASS
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=FutStore <seu@gmail.com>

# URL base do frontend, usada nos links dos e-mails
APP_URL=http://localhost:5173

# Opcional: redireciona TODOS os e-mails pra este endereço (modo dev/teste)
# MAIL_DEV_TO=
